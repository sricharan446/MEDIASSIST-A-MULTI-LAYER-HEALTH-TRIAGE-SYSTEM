# ── MediAssist — Environment Variables ─────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Your Google Gemini API key (required)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="Your Gemini API key"

# Gemini model — updated to latest (FIX 19)
MODEL_NAME=gemini-2.5-flash-lite

# Port to run the server on (optional — defaults to 8000)
PORT=80

# Path for ChromaDB persistent storage (optional)
CHROMA_DB_PATH=./chroma_db
