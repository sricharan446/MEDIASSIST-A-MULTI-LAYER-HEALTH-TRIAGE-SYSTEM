# ── Medical Assistant — Environment Variables ─────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Your Google Gemini API key (required)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AYour Gemini API key
# Default Gemini model (optional — defaults to gemini-2.0-flash)
MODEL_NAME=gemini-2.0-flash

# Port to run the server on (optional — defaults to 8000)
PORT=8000

# Path for ChromaDB persistent storage (optional)
CHROMA_DB_PATH=./chroma_db
